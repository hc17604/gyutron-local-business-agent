GYUTRON_API_PORT=8000
GYUTRON_WEB_PORT=3000
GYUTRON_DATA_DIR=./data
GYUTRON_WORKSPACE_ROOT=.
VITE_API_BASE_URL=http://localhost:8000

# GYUTRON Website connector (read-only Data API). Set these in the SHELL
# environment before starting the backend (no dotenv auto-loading):
#   PowerShell:  $env:GYUTRON_WEBSITE_API_KEY = "<key from activate-backend.ps1>"
# The key is the DATA_API_KEY printed once by the website activation script.
GYUTRON_WEBSITE_BASE_URL=https://www.gyutron.com
GYUTRON_WEBSITE_API_KEY=
